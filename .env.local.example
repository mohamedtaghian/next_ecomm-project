# MongoDB
MONGODB_URI=mongodb://localhost:27017/freshcart
# or use Atlas: mongodb+srv://user:pass@cluster.mongodb.net/freshcart

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# App URL
NEXT_PUBLIC_API_URL=http://localhost:3000

# Email (Nodemailer) - use Gmail App Password or any SMTP
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=FreshCart <your_email@gmail.com>

# Cloudinary (for image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
